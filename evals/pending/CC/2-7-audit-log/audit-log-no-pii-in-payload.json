{
  "name": "audit log: validator rejects entries containing email-like or token-like values in payload",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-audit-log.sh\" --file \"$PWD/bad.jsonl\"",
  "setup": [
    "echo '{\"timestamp\":\"2026-05-04T00:00:00Z\",\"actor\":\"x\",\"event\":\"e\",\"data\":{\"email\":\"u@e.com\"}}' > bad.jsonl"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "pii",
      "email"
    ]
  }
}
