{
  "name": "eslint-wrap: npm install failure (e.g. non-existent package) blocks rule activation with diagnostic",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/wrap-eslint.sh\" --rule-id g-test --eslint-rule x/y --eslint-plugin-npm nonexistent-plugin-xxx --eslint-plugin-version 1.0.0 --paths \"src/*\"",
  "setup": [
    "mkdir -p src && echo 'x' > src/a.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "npm install",
      "failed"
    ]
  }
}
