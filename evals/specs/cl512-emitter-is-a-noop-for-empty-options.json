{
  "name": "the emitter writes nothing when given empty options, so an unconfigured tool runs with its defaults",
  "command": "out=$(bash \"$CLAUDE_PLUGIN_ROOT/rubric/runners/emit-tool-config.sh\" --tool ruff --options '{}' --out c 2>/dev/null); [ -z \"$out\" ] && echo emitter-noop-empty 1>&2",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "emitter-noop-empty"
    ]
  }
}
