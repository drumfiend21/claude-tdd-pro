{
  "name": "rubric/changelog.md contains an entry block for every released semver version in RUBRIC.yaml",
  "command": "[ -s \"$CLAUDE_PLUGIN_ROOT/rubric/changelog.md\" ] && current=$(grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' \"$CLAUDE_PLUGIN_ROOT/rubric/RUBRIC.yaml\" | head -1) && grep -q \"$current\" \"$CLAUDE_PLUGIN_ROOT/rubric/changelog.md\" && echo ok 1>&2",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
