{
  "name": "parallel runner: omitting --concurrency defaults to os.cpus().length and is reported",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --in \"$PWD/src/**/*.js\" --report-workers 2>out.json && node -e 'const r=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));const cpus=require(\"os\").cpus().length;if(r.workers_spawned===cpus){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL got \"+r.workers_spawned+\" cpus=\"+cpus+\"\\n\");process.exit(1)}'",
  "setup": [
    "mkdir -p src && echo 'eval(1)' > src/a.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
