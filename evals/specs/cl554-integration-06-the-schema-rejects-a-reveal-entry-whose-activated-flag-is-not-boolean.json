{
  "name": "the schema rejects a full-surface reveal entry whose activated flag is not a boolean",
  "command": "node \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/lib/validate-json-schema.js\" \"$CLAUDE_PLUGIN_ROOT/schemas/business-profile.schema.json\" bad.json 2>/dev/null; [ $? -eq 2 ] && echo malformed-reveal-rejected 1>&2",
  "setup": [
    "printf '%s' '{\"workload\":\"a credentialing platform\",\"motivation\":\"revenue\",\"criticality\":\"mission-critical\",\"availability_tolerance\":\"minutes\",\"data_loss_tolerance\":\"minutes\",\"data_sensitivity\":\"confidential\",\"compliance_regime\":\"soc2\",\"scale\":\"large\",\"budget_posture\":\"balanced\"}' > p.json",
    "bash \"$CLAUDE_PLUGIN_ROOT/commands/full-surface-intake.sh\" --workload \"a credentialing platform\" --answers p.json --stack-add aws --probe-answer aws:aws_region_strategy=multi-region --partial --out prof.json --now 2026-07-08T00:00:00Z >/dev/null 2>&1",
    "ruby -rjson -e 'p=JSON.parse(File.read(\"prof.json\")); p[\"full_surface\"]=[{\"namespace\"=>\"aws\",\"activated\"=>\"yes\"}]; File.write(\"bad.json\", JSON.generate(p))'"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "malformed-reveal-rejected"
    ]
  }
}
