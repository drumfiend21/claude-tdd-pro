{
  "name": "commit format: trailers must match `^[A-Z][a-zA-Z-]+: .+$` (RFC 822-like)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-commit-msg.sh\" \"$PWD/msg.txt\"",
  "setup": [
    "printf 'feat: x\\n\\nbody.\\n\\nbroken trailer here\\n' > msg.txt"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "trailer",
      "format"
    ]
  }
}
