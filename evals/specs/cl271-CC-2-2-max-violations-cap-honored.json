{
  "name": "detector --max-violations caps findings and emits truncated=true",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/no-any.sh\" --json --paths \"src/**/*.ts\" --max-violations 3 2>out.json; bc=$?; node -e 'const r=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));if(r.findings.length===3&&r.truncated===true){process.stderr.write(\"ok\\n\");process.exit(1)}else{process.stderr.write(\"FAIL findings=\"+r.findings.length+\" truncated=\"+r.truncated+\"\\n\");process.exit(2)}'",
  "setup": ["mkdir -p src && for i in 1 2 3 4 5; do echo \"const x${i}: any = ${i};\" > src/f${i}.ts; done"],
  "expect": {
    "exit_code": 1,
    "stderr_contains": ["ok"]
  }
}
