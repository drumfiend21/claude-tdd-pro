{
  "name": "profile: regulated.yaml tightens g-react-003 (A11y P1 violations) to severity:error (P0) per industry expectations",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/profiles/resolve.sh\" \"$CLAUDE_PLUGIN_ROOT/profiles/regulated.yaml\" --emit-resolved 2>out.json && node -e 'const r=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));const rule=r.resolved_rules[\"g-react-003\"];if(rule&&(rule.severity===\"error\"||rule.severity===\"P0\")){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL severity=\"+rule.severity+\"\\n\");process.exit(1)}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
