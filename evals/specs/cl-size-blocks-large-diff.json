{
  "name": "cl-size detector flags a diff over the cap",
  "command": "RULE_ID=g-eng-004-cl-size SEVERITY=P1 CLAUDE_PROJECT_DIR=$PWD bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/cl-size.sh\" 50 1>&2",
  "setup": [
    "git init -q",
    "git config user.email t@t.test",
    "git config user.name t",
    "git config commit.gpgsign false",
    "for i in $(seq 1 80); do echo line$i >> big.txt; done",
    "git add big.txt"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": ["g-eng-004-cl-size", "split per google-eng-practices"]
  }
}
