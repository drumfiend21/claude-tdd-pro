{
  "name": "STANDARDS-URLS: each entry requires id, publisher, url, license, last_verified",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-standards-urls.sh\" \"$PWD/STANDARDS-URLS.yaml\"",
  "setup": [
    "printf 'src-1:\\n  publisher: Acme\\n' > STANDARDS-URLS.yaml"
