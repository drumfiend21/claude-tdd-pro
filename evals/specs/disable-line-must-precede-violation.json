{
  "name": "directives: disable-next-line on a later line does not suppress earlier code",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/inline-suppression.sh\" --rule no-eval --report-unused-disable-directives --in \"$PWD/file.js\" 1>&2",
  "setup": [
    "printf \"eval(x);\\\\n// rubric-disable-next-line no-eval -- misplaced\" > file.js"
  ],
  "expect": {
    "exit_code": 1,
    "stderr_contains": [
      "no-eval"
    ]
  }
}
