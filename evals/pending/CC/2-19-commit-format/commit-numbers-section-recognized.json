{
  "name": "commit format: optional Numbers: section recognized; if present, must contain ≥1 metric line",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-commit-msg.sh\" \"$PWD/msg.txt\"",
  "setup": [
    "printf 'test: x\\n\\nbody.\\n\\nNumbers:\\n\\n' > msg.txt"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "Numbers",
      "metric"
    ]
  }
}
