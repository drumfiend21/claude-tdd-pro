{
  "name": "plugin loader: scoped name \"@scope/acme\" resolves to \"@scope/eslint-plugin-acme\"",
  "command": "node -e 'const p=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/plugin-loader.js\");const path=p.resolvePluginPath(\"@scope/acme\",{cwd:process.env.PWD});if(path&&path.includes(\"@scope/eslint-plugin-acme\")){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL \"+path+\"\\n\");process.exit(1)}'",
  "setup": [
    "mkdir -p node_modules/@scope/eslint-plugin-acme && echo 'module.exports={rules:{}}' > node_modules/@scope/eslint-plugin-acme/index.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
