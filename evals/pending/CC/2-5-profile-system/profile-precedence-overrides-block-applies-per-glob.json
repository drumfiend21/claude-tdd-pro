{
  "name": "profile precedence: overrides[] block applies rule severity per matching glob",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/profiles/resolve.sh\" profile.yaml --for-file \"src/auth/session.ts\" | node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{const r=JSON.parse(s);if(r.rules[\"g-ts-001\"].severity===\"error\"){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}});'",
  "setup": [
    "echo \"extends: [standard]\\noverrides:\\n  - files: [\\\"src/auth/**\\\"]\\n    rules:\\n      g-ts-001: error\" > profile.yaml"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
