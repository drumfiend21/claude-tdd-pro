{
  "name": "rule context: context.getSourceCode().text returns the original file text byte-for-byte",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule trace-context --in \"$PWD/file.js\" --assert source-text",
  "setup": [
    "mkdir -p src && echo 'const x = 1;' > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
