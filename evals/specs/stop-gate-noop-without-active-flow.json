{
  "name": "stop-rubric-gate is a no-op when no active-flow file is set",
  "command": "CLAUDE_PROJECT_DIR=$PWD bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/stop-rubric-gate.sh\" 1>&2",
  "setup": [
    "git init -q",
    "git config user.email t@t.test",
    "git config user.name t"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_not_contains": ["BLOCKING"]
  }
}
