{
  "name": "parallel runner: an uncaught exception inside a worker propagates to the main thread and exits non-zero",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule throw-during-create --in \"$PWD/src/**/*.js\" --concurrency 4",
  "setup": [
    "mkdir -p src && echo 'const x = 1;' > src/a.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "worker",
      "exception"
    ]
  }
}
