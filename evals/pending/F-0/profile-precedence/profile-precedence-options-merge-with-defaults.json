{
  "name": "profile precedence: rule options merge operator overrides into rule schema defaults (§2.5 + E-2)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/profiles/resolve.sh\" profile.yaml | node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{const r=JSON.parse(s);const opts=r.rules[\"g-ts-001\"].options;if(opts.allow_with_comment===false&&opts.max_per_file===0){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}});'",
  "setup": [
    "echo \"rules:\\n  g-ts-001: [\\\"error\\\", { allow_with_comment: false }]\" > profile.yaml"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
