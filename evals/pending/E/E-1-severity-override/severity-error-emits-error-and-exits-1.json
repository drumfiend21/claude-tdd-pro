{
  "name": "severity resolver: severity 2/\"error\" produces an error and CLI exits 1",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --severity error --in \"$PWD/file.js\" --report-format json 2>out.json",
  "setup": [
    "echo 'eval(x)' > file.js"
  ],
  "expect": {
    "exit_code": 1,
    "stderr_contains": [
      "\"severity\":2"
    ]
  }
}
