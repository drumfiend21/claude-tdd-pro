{
  "name": "rule context: context.languageOptions.ecmaVersion is set to the configured ECMAScript version",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule trace-context --in \"$PWD/file.js\" --assert language-options-version",
  "setup": [
    "mkdir -p src && echo 'const x = 1;' > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
