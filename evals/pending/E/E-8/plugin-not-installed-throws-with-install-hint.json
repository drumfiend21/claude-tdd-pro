{
  "name": "plugin loader: missing plugin throws an error containing \"npm install\" hint",
  "command": "node -e 'const p=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/plugin-loader.js\");try{p.loadPlugin(\"nonexistent\",{cwd:process.env.PWD});process.stderr.write(\"FAIL\\n\");process.exit(1)}catch(e){if(/npm install|not installed/i.test(e.message)){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL: \"+e.message+\"\\n\");process.exit(1)}}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
