{
  "name": "a file-render tool (eslint) still projects its options to its native config file (no regression)",
  "command": "p=$(bash \"$CLAUDE_PLUGIN_ROOT/rubric/runners/emit-tool-config.sh\" --tool eslint --options '{\"complexity\":[\"error\",{\"max\":10}]}' --out . 2>/dev/null); [ -f \"$p\" ] && grep -q 'complexity' \"$p\" && echo eslint-projects 1>&2",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "eslint-projects"
    ]
  }
}
