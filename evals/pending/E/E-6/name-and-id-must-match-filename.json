{
  "name": "rule meta: when auto-loaded, registered id must equal the source filename without extension",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --validate-meta --rule-file \"$PWD/rules/wrong-name.js\"",
  "setup": [
    "mkdir -p rules",
    "echo 'module.exports={meta:{type:\"problem\",name:\"different-name\"},create:()=>({})}' > rules/wrong-name.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "mismatch"
    ]
  }
}
