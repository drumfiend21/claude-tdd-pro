{
  "name": "AST walker: matches selector `VariableDeclaration ~ FunctionDeclaration` (general sibling (anywhere after, same parent))",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule selector-trace --selector \"VariableDeclaration ~ FunctionDeclaration\" --in \"$PWD/file.js\"",
  "setup": [
    "echo \"const x = 1;\\\\nconst y = 2;\\\\nfunction f(){}\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "matched"
    ]
  }
}
