{
  "name": "severity resolver: rules not present in config default to off and do not run",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --config '{}' --in \"$PWD/file.js\" --report-format json 2>out.json && [ \"$(node -e 'console.log(JSON.parse(require(\\\"fs\\\").readFileSync(\\\"out.json\\\",\\\"utf8\\\")).messages.length)')\" = \"0\" ] && echo ok 1>&2",
  "setup": [
    "echo 'eval(x)' > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
