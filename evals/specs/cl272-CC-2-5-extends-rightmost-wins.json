{
  "name": "profile precedence: rightmost extends entry wins on inherited conflict",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/profiles/resolve.sh\" profile.yaml | node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{const r=JSON.parse(s);if(r.rules[\"g-ts-001\"].severity===\"error\"){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}});'",
  "setup": [
    "printf '%s\\n' 'extends: [lite, strict]' > profile.yaml"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
