{
  "name": "sod gate: a commit with no .claude-tdd-pro/verify/<pr-sha>.json on disk is blocked",
  "command": "mkdir -p .claude-tdd-pro/verify && bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/sod-gate.sh\" --pr-sha abc123 --verifier-output \"$PWD/.claude-tdd-pro/verify/abc123.json\" --enforce",
  "setup": [],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "verifier",
      "missing"
    ]
  }
}
