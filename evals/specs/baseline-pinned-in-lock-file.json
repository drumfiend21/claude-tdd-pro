{
  "name": "telemetry baseline: baseline content_hash is pinned in lock.json (drift from baseline detected on subsequent runs)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/commands/init-guardrails.sh\" --emit-baseline \"$PWD/.claude-tdd-pro/telemetry-baseline.json\" && bash \"$CLAUDE_PLUGIN_ROOT/rubric/lock.sh\" --pin-baseline && grep -E '\"telemetry_baseline_hash\":\"sha256:' .claude-tdd-pro/lock.json 1>&2 && echo ok 1>&2",
  "setup": [
    "mkdir -p .claude-tdd-pro && bash \"$CLAUDE_PLUGIN_ROOT/rubric/lock.sh\" --init"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
