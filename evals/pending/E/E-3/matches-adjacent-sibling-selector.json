{
  "name": "AST walker: matches selector `VariableDeclaration + FunctionDeclaration` (adjacent sibling)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule selector-trace --selector \"VariableDeclaration + FunctionDeclaration\" --in \"$PWD/file.js\"",
  "setup": [
    "echo \"const x = 1;\\\\nfunction f(){}\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "matched"
    ]
  }
}
