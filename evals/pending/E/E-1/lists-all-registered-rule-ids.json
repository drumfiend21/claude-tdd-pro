{
  "name": "rule registry: listRules() returns a sorted array of all registered rule ids",
  "command": "node -e 'const r=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/registry.js\");const ids=r.listRules();const sorted=[...ids].sort();if(JSON.stringify(ids)===JSON.stringify(sorted)&&ids.length>0){process.stderr.write(\"ok count=\"+ids.length+\"\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
