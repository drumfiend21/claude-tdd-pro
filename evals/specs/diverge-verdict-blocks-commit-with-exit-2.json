{
  "name": "sod gate: diverge verdict blocks the commit (exit 2) and surfaces the divergence",
  "command": "mkdir -p .claude-tdd-pro/verify && printf '{\"pr_sha\":\"abc123\",\"verdict\":\"diverge\",\"reviewer\":\"verifier-bot\",\"reason\":\"control-id mismatch\"}' > .claude-tdd-pro/verify/abc123.json && bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/sod-gate.sh\" --pr-sha abc123 --verifier-output \"$PWD/.claude-tdd-pro/verify/abc123.json\" --enforce",
  "setup": [],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "diverge",
      "control-id mismatch"
    ]
  }
}
