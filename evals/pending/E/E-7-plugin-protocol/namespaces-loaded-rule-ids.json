{
  "name": "plugin loader: loaded rule \"foo\" from plugin \"acme\" is registered as \"acme/foo\"",
  "command": "node -e 'const p=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/plugin-loader.js\");const r=p.loadPlugin(\"acme\",{cwd:process.env.PWD});const reg=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/registry.js\");if(reg.loadRule(\"acme/foo\")){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}'",
  "setup": [
    "mkdir -p node_modules/eslint-plugin-acme && echo 'module.exports={rules:{foo:{meta:{type:\"problem\"},create:()=>({})}}}' > node_modules/eslint-plugin-acme/index.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
