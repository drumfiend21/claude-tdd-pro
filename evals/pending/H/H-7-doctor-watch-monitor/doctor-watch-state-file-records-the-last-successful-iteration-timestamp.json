{
  "name": "/doctor --watch state file records the last successful iteration timestamp",
  "command": "mkdir -p .claude-tdd-pro && bash \"$CLAUDE_PLUGIN_ROOT/commands/doctor.sh\" --watch --once --state .claude-tdd-pro/doctor-watch-state.json --now 2026-05-13T00:00:00Z 2>err.txt && grep -q '\"last_iteration_at\":\"2026-05-13T00:00:00Z\"' .claude-tdd-pro/doctor-watch-state.json && echo ok 1>&2",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
