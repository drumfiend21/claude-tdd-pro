{
  "name": "directives: unused disable comment is reported when --report-unused-disable-directives",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --severity error --report-unused-disable-directives --in \"$PWD/file.js\" 1>&2",
  "setup": [
    "printf \"// eslint-disable-next-line no-eval\\\\nconst x = 1;\" > file.js"
  ],
  "expect": {
    "exit_code": 1,
    "stderr_contains": [
      "unused"
    ]
  }
}
