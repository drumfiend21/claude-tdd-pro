{
  "name": "template: tsconfig.strict.json has compilerOptions.noUncheckedIndexedAccess:true per T-4 list",
  "command": "node -e 'const c=JSON.parse(require(\"fs\").readFileSync(process.env.CLAUDE_PLUGIN_ROOT+\"/templates/tsconfig.strict.json\",\"utf8\"));if(c.compilerOptions&&c.compilerOptions.noUncheckedIndexedAccess===true){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL noUncheckedIndexedAccess\\n\");process.exit(1)}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
