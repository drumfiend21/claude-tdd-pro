.DS_Store
node_modules/
*.log
.env
.env.local

# Eval runner perf log — append-only JSONL of timing samples per
# `bash scripts/eval-perf-log.sh` invocation. Machine-local; rebuilt
# on demand; never committed.
.claude-tdd-pro/eval-perf.jsonl

# Eval runner spec-result cache. Machine-local; rebuilt on demand.
# Markers under .claude-tdd-pro/eval-cache/<sha>.passed are touched when
# a spec passes; the substrate-tree hash is part of the key so any change
# under rubric/, commands/, agents/, skills/, hooks/, profiles/, schemas/,
# compliance/, generated-code-quality-standards/, templates/, scripts/,
# space/, seed/, migrations/, standards/, design-tokens/, prompts/,
# pr-corpus/, lsp/, scaffolds/, vscode-tdd-pro/, community/,
# community-shared/ derives a fresh key and invalidates the cache.
.claude-tdd-pro/eval-cache/
.claude-tdd-pro/cache/

# Q-6 SPACE local data — gitignored by default per privacy posture.
# Only the user-data subtree is private; substrate scripts under space/ are
# code and must remain tracked (prior `space/` blanket ignore silently dropped
# space/cross-loop-emit.sh, honest-scope-validate.sh, retention-sweep.sh,
# README.md from CL-137/138 commits).
.claude-tdd-pro/space/
space/.local/

# Per-session scheduled-task lock (machine/session state, not source)
.claude/scheduled_tasks.lock

# Universal-coverage refresh runtime state (§28.22/§28.23) — never committed
standards/universal-coverage-ledger.jsonl
.claude-tdd-pro/standards-last-fetch/
.claude-tdd-pro/FETCH-FREQUENCIES.yaml
results.sarif
results_sarif.sarif
