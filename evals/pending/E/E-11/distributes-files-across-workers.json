{
  "name": "parallel runner: file load balanced across workers (each worker processes >= 1 file when files >= concurrency)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --in \"$PWD/src/**/*.js\" --concurrency 4 --report-workers 2>out.json && node -e 'const r=JSON.parse(require(\\\"fs\\\").readFileSync(\\\"out.json\\\",\\\"utf8\\\"));if(r.per_worker_files.every(n=>n>=1)){process.stderr.write(\\\"ok\\\\n\\\")}else{process.stderr.write(\\\"FAIL: \\\"+JSON.stringify(r.per_worker_files)+\\\"\\\\n\\\");process.exit(1)}' 1>&2",
  "setup": [
    "mkdir -p src && for i in $(seq 1 40); do echo \"const x = ${i};\" > src/f${i}.js; done"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
