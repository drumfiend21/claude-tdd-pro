{
  "name": "fixer API: fixer.replaceTextRange([start,end], 'newText') replaces exact range",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule \"fixer-replace-range\" --in \"$PWD/file.js\" --fix && diff <(printf %s \"beforeNEW\") file.js 1>&2 && echo ok 1>&2",
  "setup": [
    "printf %s \"before\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
