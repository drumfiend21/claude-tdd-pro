{
  "name": "detector reads CLAUDE_TDD_PRO_DETECTOR_CONFIG to override default options",
  "command": "echo '{\"max_violations\":2}' > cfg.json && CLAUDE_TDD_PRO_DETECTOR_CONFIG=\"$PWD/cfg.json\" bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/no-any.sh\" --json --paths \"src/**/*.ts\" 2>out.json; node -e 'const r=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));if(r.findings.length===2){process.stderr.write(\"ok\\n\");process.exit(1)}else{process.stderr.write(\"FAIL findings=\"+r.findings.length+\"\\n\");process.exit(2)}'",
  "setup": ["mkdir -p src && for i in 1 2 3 4 5; do echo \"const x${i}: any = ${i};\" > src/f${i}.ts; done"],
  "expect": {"exit_code": 1, "stderr_contains": ["ok"]}
}
