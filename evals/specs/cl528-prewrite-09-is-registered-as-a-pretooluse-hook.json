{
  "name": "the pre-write governor is registered as a PreToolUse Edit/Write hook so it runs before every write",
  "command": "node -e 'const h=JSON.parse(require(\"fs\").readFileSync(process.argv[1],\"utf8\"));const pre=h.hooks.PreToolUse||[];const cmds=pre.flatMap(g=>(g.hooks||[]).map(x=>x.command));process.exit(cmds.some(c=>/enforce-standards-pre-write\\.sh/.test(c))?0:1)' \"$CLAUDE_PLUGIN_ROOT/hooks/hooks.json\" && echo registered-pretooluse 1>&2",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "registered-pretooluse"
    ]
  }
}
