{
  "name": "directives: disable-next-line on a later line does not suppress earlier code",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --severity error --report-unused-disable-directives --in \"$PWD/file.js\" 1>&2",
  "setup": [
    "printf \"eval(x);\\\\n// eslint-disable-next-line no-eval\" > file.js"
  ],
  "expect": {
    "exit_code": 1,
    "stderr_contains": [
      "no-eval"
    ]
  }
}
