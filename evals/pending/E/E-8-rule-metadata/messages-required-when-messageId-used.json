{
  "name": "rule meta: if any context.report uses messageId, rule.meta.messages must define it",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --validate-meta --rule-file \"$PWD/rule.js\"",
  "setup": [
    "echo \"module.exports={\\\"meta\\\":{\\\"type\\\":\\\"problem\\\",\\\"messages\\\":{}},\\\"create\\\":(c)=>({Program:n=>c.report({node:n,messageId:\\\"missing\\\"})})}\" > rule.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "messageId"
    ]
  }
}
