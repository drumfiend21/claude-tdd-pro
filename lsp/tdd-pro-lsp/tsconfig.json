{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "./out",
    "rootDir": "./src",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
