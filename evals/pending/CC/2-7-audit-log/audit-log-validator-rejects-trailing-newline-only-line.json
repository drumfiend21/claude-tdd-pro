{
  "name": "audit log: validator rejects log files containing blank/whitespace-only lines (each line must be JSON)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-audit-log.sh\" --file \"$PWD/bad.jsonl\"",
  "setup": [
    "printf '{\"timestamp\":\"2026-05-04T00:00:00Z\",\"actor\":\"x\",\"event\":\"e\"}\\n\\n' > bad.jsonl"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "blank line",
      "line 2"
    ]
  }
}
