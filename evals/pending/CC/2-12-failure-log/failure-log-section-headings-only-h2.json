{
  "name": "FAILURE-LOG: validator rejects date headings written as anything other than ## (H2)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-failure-log.sh\" \"$PWD/FAILURE-LOG.md\"",
  "setup": [
    "printf '# Failure Log\\n\\n### 2026-05-04\\n- bug\\n' > FAILURE-LOG.md"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "heading",
      "H2"
    ]
  }
}
