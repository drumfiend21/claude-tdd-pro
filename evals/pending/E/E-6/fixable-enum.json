{
  "name": "rule meta: rule.meta.fixable must be one of {null, \"code\", \"whitespace\"}",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --validate-meta --rule-file \"$PWD/rule.js\"",
  "setup": [
    "echo \"module.exports={\\\"meta\\\":{\\\"type\\\":\\\"problem\\\",\\\"fixable\\\":\\\"yes\\\"},\\\"create\\\":()=>({})}\" > rule.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "fixable"
    ]
  }
}
