{
  "name": "commit format: BREAKING CHANGE: footer or \"feat!:\" prefix triggers a CHANGELOG-update reminder (warning, exit 1)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-commit-msg.sh\" \"$PWD/msg.txt\"",
  "setup": [
    "printf 'feat!: drop legacy api\\n\\nbody.\\n' > msg.txt"
  ],
  "expect": {
    "exit_code": 1,
    "stderr_contains": [
      "CHANGELOG",
      "breaking"
    ]
  }
}
