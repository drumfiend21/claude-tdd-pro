{
  "name": "suggestions: a single report can include multiple suggestion alternatives",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule suggest-multi --in \"$PWD/file.js\" --report-format json 2>out.json && node -e 'const r=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));if(r.messages[0].suggestions.length>=2){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}'",
  "setup": [
    "echo 'const x = 1;' > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
