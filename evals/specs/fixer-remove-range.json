{
  "name": "fixer API: fixer.removeRange([start,end]) deletes the byte range",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/commands/fix-rules.sh\" --rule \"fixer-remove-range\" --in \"$PWD/file.js\" --fix && diff <(printf %s \"beforeafter\") file.js 1>&2 && echo ok 1>&2",
  "setup": [
    "printf %s \"beforeJUNKafter\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
