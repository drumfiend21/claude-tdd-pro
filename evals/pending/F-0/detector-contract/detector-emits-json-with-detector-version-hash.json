{
  "name": "detector contract: --json output includes detector_version_hash field",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/no-any.sh\" --json --paths \"src/**/*.ts\" | node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{const r=JSON.parse(s);if(typeof r.detector_version_hash===\"string\"&&r.detector_version_hash.length>0){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL: missing detector_version_hash\\n\");process.exit(1)}});'",
  "setup": [
    "mkdir -p src && echo \"const x: any = 1;\" > src/a.ts"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
