{
  "name": "plugin loader: calling loadPlugin twice with same name returns the same module without re-registering rules",
  "command": "node -e 'const p=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/plugin-loader.js\");const a=p.loadPlugin(\"acme\",{cwd:process.env.PWD});const b=p.loadPlugin(\"acme\",{cwd:process.env.PWD});if(a===b){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}'",
  "setup": [
    "mkdir -p node_modules/eslint-plugin-acme && echo 'module.exports={rules:{foo:{meta:{type:\"problem\"},create:()=>({})}}}' > node_modules/eslint-plugin-acme/index.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
