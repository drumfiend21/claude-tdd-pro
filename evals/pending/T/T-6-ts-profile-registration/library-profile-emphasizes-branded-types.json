{
  "name": "profile: library.yaml elevates g-ts-005 (branded types) to severity:error since libraries need stricter boundary types",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/profiles/resolve.sh\" \"$CLAUDE_PLUGIN_ROOT/profiles/library.yaml\" --emit-resolved 2>out.json && node -e 'const r=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));const rule=r.resolved_rules[\"g-ts-005\"];if(rule&&(rule.severity===\"error\"||rule.severity===\"P0\")){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL severity=\"+(rule&&rule.severity)+\"\\n\");process.exit(1)}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
