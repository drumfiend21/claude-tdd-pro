{
  "name": "secret-scan blocks .env file by name even with empty content",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/secret-scan.sh\"",
  "setup": [
    "git init -q",
    "git config user.email t@t.test",
    "git config user.name t",
    "echo 'FOO=bar' > .env",
    "git add ."
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [".env", "REFUSING"]
  }
}
