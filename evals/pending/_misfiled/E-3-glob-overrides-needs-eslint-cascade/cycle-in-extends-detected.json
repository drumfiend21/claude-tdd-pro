{
  "name": "config cascade: a cycle in extends:[] is detected and reported with the cycle path",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --in \"$PWD/file.js\"",
  "setup": [
    "mkdir -p node_modules/eslint-config-a node_modules/eslint-config-b",
    "echo 'module.exports={extends:[\"b\"]}' > node_modules/eslint-config-a/index.js",
    "echo 'module.exports={extends:[\"a\"]}' > node_modules/eslint-config-b/index.js",
    "echo 'module.exports={extends:[\"a\"]}' > rule-engine.config.js",
    "echo 'x' > file.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "cycle",
      "extends"
    ]
  }
}
