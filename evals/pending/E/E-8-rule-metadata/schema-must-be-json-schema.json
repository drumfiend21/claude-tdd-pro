{
  "name": "rule meta: rule.meta.schema must be a valid JSON Schema document or array thereof",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --validate-meta --rule-file \"$PWD/rule.js\"",
  "setup": [
    "echo \"module.exports={\\\"meta\\\":{\\\"type\\\":\\\"problem\\\",\\\"schema\\\":\\\"not-json-schema\\\"},\\\"create\\\":()=>({})}\" > rule.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "schema"
    ]
  }
}
