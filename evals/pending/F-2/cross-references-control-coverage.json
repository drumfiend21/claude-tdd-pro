{
  "name": "F-2 /measure-rubric: cross-references control coverage (C-9) per rule",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/commands/measure-rubric.sh\" --format json | node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d);process.stdin.on(\"end\",()=>{const r=JSON.parse(s);const rule=Object.values(r.runs_per_rule||{})[0];if(rule&&Array.isArray(rule.controls_satisfied)){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}});'",
  "setup": [
    "git init -q && git config user.email t@t && git config user.name t && echo x>f && git add f && git commit -q -m c"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
