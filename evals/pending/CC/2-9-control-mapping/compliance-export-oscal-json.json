{
  "name": "compliance: --export oscal writes an OSCAL component-definition JSON",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/compliance-export.sh\" --compliance \"$PWD/COMPLIANCE.yaml\" --format oscal --out \"$PWD/out.json\" && node -e 'const j=JSON.parse(require(\"fs\").readFileSync(\"out.json\",\"utf8\"));if(j[\"component-definition\"]){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}'",
  "setup": [
    "printf 'PCI-DSS:\\n  6.5.1:\\n    - r1\\n' > COMPLIANCE.yaml"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
