{
  "name": "commit format: scope (between parens) must be a single kebab-case token (no spaces, no commas)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/validate-commit-msg.sh\" \"$PWD/msg.txt\"",
  "setup": [
    "printf 'feat(rule engine, lint): x\\n\\nbody.\\n' > msg.txt"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "scope"
    ]
  }
}
