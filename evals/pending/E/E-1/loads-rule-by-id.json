{
  "name": "rule registry: loadRule(id) returns the registered rule object for a known id",
  "command": "node -e 'const r=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/registry.js\");const rule=r.loadRule(\"no-eval\");if(rule&&rule.meta&&rule.create){process.stderr.write(\"ok\\n\")}else{process.stderr.write(\"FAIL\\n\");process.exit(1)}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
