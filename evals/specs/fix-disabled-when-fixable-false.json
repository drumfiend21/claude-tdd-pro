{
  "name": "fixer API: rule.meta.fixable===null disables --fix even if fixer called",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/commands/fix-rules.sh\" --rule \"fixer-disabled\" --in \"$PWD/file.js\" --fix && diff <(printf %s \"foo()\") file.js 1>&2 && echo ok 1>&2",
  "setup": [
    "printf %s \"foo()\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
