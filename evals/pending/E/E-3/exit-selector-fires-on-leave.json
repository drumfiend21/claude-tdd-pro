{
  "name": "AST walker: matches selector `Program:exit` (on Program leave)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule selector-trace --selector \"Program:exit\" --in \"$PWD/file.js\"",
  "setup": [
    "echo \"const x = 1;\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "matched"
    ]
  }
}
