{
  "name": "lock contracts: lock file `rubric_semver` field pins the rubric schema version (per §2.7)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/lock.sh\" --init && grep -E '\"rubric_semver\":\"[0-9]+\\.[0-9]+\\.[0-9]+\"' .claude-tdd-pro/lock.json 1>&2 && echo ok 1>&2",
  "setup": [
    "mkdir -p .claude-tdd-pro"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
