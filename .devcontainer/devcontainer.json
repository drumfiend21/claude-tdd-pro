{
  "name": "Claude TDD Pro dev container",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/ruby:1": { "version": "3.3" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  },
  "postCreateCommand": "bash scripts/ci-validate-all.sh || true",
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/claude-tdd-pro",
  "forwardPorts": [],
  "customizations": {
    "vscode": {
      "extensions": [
        "claude-tdd-pro.vscode-tdd-pro"
      ]
    }
  }
}
