{
  "name": "rule registry: bootstrap auto-loads every rule-engine/rules/*.js as a rule keyed by filename",
  "command": "node -e 'const r=require(\"$CLAUDE_PLUGIN_ROOT/rule-engine/registry.js\");const ids=r.listRules();const fs=require(\"fs\"),path=require(\"path\");const files=fs.readdirSync(\"$CLAUDE_PLUGIN_ROOT/rule-engine/rules\").filter(f=>f.endsWith(\".js\")).map(f=>f.replace(/\\.js$/,\"\"));const missing=files.filter(f=>!ids.includes(f));if(missing.length===0){process.stderr.write(\"ok auto-loaded=\"+files.length+\"\\n\")}else{process.stderr.write(\"FAIL missing \"+missing.join(\",\")+\"\\n\");process.exit(1)}'",
  "setup": [],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
