{
  "name": "directives: shebang line is not treated as a disable comment",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rubric/detectors/inline-suppression.sh\" --rule no-eval --report-unused-disable-directives --in \"$PWD/file.js\" 1>&2",
  "setup": [
    "printf \"#!/usr/bin/env node\\\\neval(x)\" > file.js"
  ],
  "expect": {
    "exit_code": 1,
    "stderr_contains": [
      "no-eval"
    ]
  }
}
