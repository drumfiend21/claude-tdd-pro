{
  "name": "AST walker: matches selector `CallExpression, NewExpression` (call or new)",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule selector-trace --selector \"CallExpression, NewExpression\" --in \"$PWD/file.js\"",
  "setup": [
    "echo \"foo(); new Bar();\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "matched"
    ]
  }
}
