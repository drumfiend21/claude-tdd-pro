{
  "name": "directives: trailing directive disables current line",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --rule no-eval --severity error --report-unused-disable-directives --in \"$PWD/file.js\" 1>&2 && echo ok 1>&2",
  "setup": [
    "printf \"eval(x); // eslint-disable-line no-eval\" > file.js"
  ],
  "expect": {
    "exit_code": 0,
    "stderr_contains": [
      "ok"
    ]
  }
}
