{
  "name": "rule meta: rule.meta.deprecated.replacedBy must be array of rule ids",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/rule-engine/cli.sh\" --validate-meta --rule-file \"$PWD/rule.js\"",
  "setup": [
    "echo \"module.exports={\\\"meta\\\":{\\\"type\\\":\\\"problem\\\",\\\"deprecated\\\":{\\\"replacedBy\\\":\\\"old/foo\\\"}},\\\"create\\\":()=>({})}\" > rule.js"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": [
      "replacedBy"
    ]
  }
}
