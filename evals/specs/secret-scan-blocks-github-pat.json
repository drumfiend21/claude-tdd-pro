{
  "name": "secret-scan blocks GitHub personal access token in staged diff",
  "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/secret-scan.sh\"",
  "setup": [
    "git init -q",
    "git config user.email t@t.test",
    "git config user.name t",
    "echo 'GITHUB_TOKEN=ghp_abcdefghijklmnopqrstuvwxyzABCDEFGHIJ' > config.txt",
    "git add config.txt"
  ],
  "expect": {
    "exit_code": 2,
    "stderr_contains": ["ghp_", "REFUSING"]
  }
}
